    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet">
    
    <style>
        :root { --navy: #0F172A; --gold: #C5A059; }
        body { font-family: 'Inter', sans-serif; background-color: #fcfcfc; scroll-behavior: smooth; }
        h1, h2, h3 { font-family: 'Playfair Display', serif; }
        
        .partner-card {
            border: 1px solid #e2e8f0;
            background: white;
            transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
        }

        .partner-card:hover {
            border-color: var(--gold);
            transform: translateY(-8px);
            box-shadow: 0 30px 60px -12px rgba(15, 23, 42, 0.15);
        }

        .image-container {
            position: relative;
            overflow: hidden;
            background: var(--navy);
            aspect-ratio: 4 / 3.5; 
        }

        .partner-img {
            filter: grayscale(100%);
            transition: all 0.8s ease;
            object-fit: cover;
            object-position: top;
        }

        .partner-card:hover .partner-img {
            filter: grayscale(0%);
            transform: scale(1.03);
        }

        .gold-line {
            width: 30px;
            height: 2px;
            background: var(--gold);
            transition: width 0.4s ease;
        }

        .partner-card:hover .gold-line {
            width: 60px;
        }

        #mobile-overlay.active {
            transform: translateX(0);
        }
    </style>
